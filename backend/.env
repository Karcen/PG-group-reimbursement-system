# ============================================================
# 实验室报销管理系统 — 后端环境变量配置
# 复制此文件为 .env 并修改相应配置
# ============================================================

# ─── 应用基础 ──────────────────────────────────────────────
# 应用运行环境：development / production
APP_ENV=development

# 应用名称（出现在 API 文档标题）
APP_NAME=实验室报销管理系统

# 后端监听地址与端口
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── 安全 ─────────────────────────────────────────────────
# JWT 签名密钥（生产环境必须修改为随机 32 位以上字符串）
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars

# JWT Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Refresh Token 有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 数据库 ───────────────────────────────────────────────
# SQLite 数据库路径
DATABASE_URL=sqlite:///./database/reimbursement.db

# ─── 文件存储 ─────────────────────────────────────────────
# 存储根目录（绝对或相对路径）
STORAGE_ROOT=./storage

# 允许上传的最大文件大小（MB）
MAX_UPLOAD_SIZE_MB=50

# ─── OCR ──────────────────────────────────────────────────
# PaddleOCR 语言（ch=中文，en=英文）
OCR_LANG=ch

# OCR 置信度阈值（低于此值标记为低置信度）
OCR_CONFIDENCE_THRESHOLD=0.6

# ─── AI（Ollama） ─────────────────────────────────────────
# Ollama 服务地址（本地运行时通常为 localhost:11434）
OLLAMA_BASE_URL=http://localhost:11434

# 默认使用的模型
OLLAMA_MODEL=qwen3

# AI 请求超时（秒）
OLLAMA_TIMEOUT=120

# ─── 业务规则 ─────────────────────────────────────────────
# 报销金额与 OCR 识别金额允许的最大差值（超过则禁止提交）
AMOUNT_DIFF_THRESHOLD=1.0

# 付款凭证金额门槛（元）：报销金额超过此值时必须附上转账截图
# 支持银行卡、支付宝、微信等付款方式截图
PAYMENT_RECORD_THRESHOLD=200.0

# 审批超时自动提醒间隔（小时）
APPROVAL_REMINDER_INTERVAL_HOURS=24

# 审批超时阈值（小时，超过此时间未审批则触发提醒）
APPROVAL_TIMEOUT_HOURS=72

# ─── 日志 ──────────────────────────────────────────────────
# 日志目录
LOG_DIR=./logs

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ─── CORS ──────────────────────────────────────────────────
# 允许跨域的前端地址（多个用逗号分隔）
CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]

# ─── 首次初始化 ────────────────────────────────────────────
# 初始管理员用户名（init_db 脚本使用）
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=Admin@123456
INIT_ADMIN_EMAIL=admin@lab.edu.cn
